{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "kassir-miniapp",
  "main": "worker/index.js",
  "compatibility_date": "2026-03-24",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "assets": {
    "directory": "dist"
  },
  "triggers": {
    "crons": [
      "*/30 * * * *"
    ]
  },
  "observability": {
    "enabled": true,
    "traces": {
      "enabled": true
    }
  }
}